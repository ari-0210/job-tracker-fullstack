# ===================================================================
# General / OS
# ===================================================================
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# macOS specific
.DS_Store


# ===================================================================
# IDE and Editor Files
# ===================================================================
# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# VS Code
.vscode/*
!.vscode/extensions.json

# STS (Spring Tool Suite)
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/


# ===================================================================
# Backend (Java / Maven / Spring Boot)
# ===================================================================
# Compiled output from Maven/Gradle
/backend/target/
/backend/build/

# Ignore .jar files created by Maven wrapper, but not the wrapper itself
!/backend/.mvn/wrapper/maven-wrapper.jar

# Help file generated by Spring Initializr
HELP.md


# ===================================================================
# Frontend (Node.js / Vue / Vite)
# ===================================================================
# Dependencies
/frontend/node_modules/

# Build output
/frontend/dist/
/frontend/dist-ssr/

# Local config files
/frontend/*.local

# ===================================================================
# Sensitive Configuration & Docker (IMPORTANT!)
# ===================================================================
# 忽略 Docker 的环境变量文件
.env

# 忽略后端所有真实的配置文件
/backend/src/main/resources/application.properties
/backend/src/main/resources/application-*.properties
/backend/src/main/resources/application-*.yml

# 忽略 Docker Compose 运行产生的本地挂载数据
/logs/
/mysql-data/  # 如果你把卷挂载到了本地路径
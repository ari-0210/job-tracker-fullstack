# ===================================================================
# JobTracker Application Properties Template (.example)
# ??????? application.properties ??????/???????
# ===================================================================
spring.application.name=DDLTracker
spring.profiles.active=jpa

# -------------------------------------------------------------------
# 1. Database Configuration
# -------------------------------------------------------------------
# ????????? your_db_name ????????????
spring.datasource.url=jdbc:mysql://localhost:3306/your_db_name
spring.datasource.username=your_db_username
spring.datasource.password=YOUR_DATABASE_PASSWORD
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=false

# -------------------------------------------------------------------
# 2. Security & JWT Configuration
# -------------------------------------------------------------------
# ????????????????????? JWT_SECRET ?????????? fallback ???
jwt.secret=${JWT_SECRET:YOUR_SUPER_SECRET_JWT_KEY_HERE_WHICH_IS_VERY_LONG_AND_SAFE}
# 24?????? (86400000 ms)
jwt.expiration.ms=86400000

# -------------------------------------------------------------------
# 3. Redis Cache Configuration
# -------------------------------------------------------------------
spring.data.redis.host=localhost
spring.data.redis.port=6379
spring.data.redis.database=0
spring.data.redis.password=YOUR_REDIS_PASSWORD_HERE

# -------------------------------------------------------------------
# 4. File Upload Assets Infrastructure
# -------------------------------------------------------------------
# ??????????? Linux ?????????
file.upload-path=${FILE_UPLOAD_PATH:/var/data/jobtracker/uploads}
spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=50MB


